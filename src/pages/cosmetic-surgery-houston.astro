                    <div class="row">
                        <h2 class="wow fadeInUp center text-center">Choose to work with Houston’s leading cosmetic surgery, and <a href="/contact-us">schedule your initial consultation</a> today!</h2>
                    </div>
                </div>               
            </section>
            



            <section>
                <div class="container-fluid">
                    <div class="row">
                        
                    </div>
                </div>
            </section>
  <section>
    <div class="container-fluid">
      <div class="row">
        <CategoryGrid categories={CATEGORIES_TOP} />
