                                                    <span class="text">My Whole Life</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Just Happened" name="consult[option_one][]" />
                                                    <span class="text">Just Happened</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Other" name="consult[option_one][]" />
