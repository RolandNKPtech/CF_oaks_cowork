  description="Virtual Consult in Houston, TX at The Oaks Plastic Surgery. Board-certified plastic surgeons offering personalized care."
  headerTitle="Virtual Consult"
  headerImage="/img/virtual-consult-hero.jpg"
  headerMarginBottom={60}
  canonical="https://theoaksplasticsurgery.com/virtual-consult"
>
<section class="mb-0">
                <div class="container-fluid">
                    <div class="row mx-auto" style="max-width: 1300px">
                        <!-- <div class="col-lg-12"> -->
                            <div class="lead text-center">
                                <p class="wow fadeInUp">
                                Congratulations on Taking your 1st step on your Journey
                                </p>
                                <h2 class="lead-heading text-h-mort">3 Easy Steps</h2>
                                <div class="lead-steps">
                                    <a href="#virtual-consult-1"><span>Send Contact / Demographic Form</span></a>
                                    <a href="#virtual-consult-2"><span>The Oaks will contact you via text in 24 to 48 hours to confirm</span></a>
                                    <a href="#virtual-consult-3"><span>Touch MD</span></a>
                                </div>
                            </div>
