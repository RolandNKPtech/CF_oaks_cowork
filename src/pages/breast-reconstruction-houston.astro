        <div class="container-fluid">
            
        </div>
    </section> -->
    <section>
        <div class="container-fluid">
            <div class="row">
                
            </div>
        </div>
    </section>
  <section>
    <div class="container-fluid">
      <div class="row">
        <CategoryGrid categories={CATEGORIES_TOP} />
      </div>
    </div>
  </section>
</Base>
