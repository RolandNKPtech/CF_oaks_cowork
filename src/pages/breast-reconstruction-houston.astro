export const prerender = true;

import Base from "../layouts/Base.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { CATEGORIES_TOP } from "../lib/categories";
---

<Base
  title="Breast Reconstruction in Houston Texas | The Oaks Plastic Surgery"
  description="Breast Reconstruction in Houston Texas at The Oaks Plastic Surgery. Board-certified plastic surgeons offering personalized care."
  headerTitle="Breast Reconstruction in Houston Texas"
  headerImage="/img/breast-reduction-hero.jpg"
  headerMarginBottom={60}
  canonical="https://theoaksplasticsurgery.com/breast-reconstruction-houston"
>
<section class="mb-0">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 offset-lg-2">
                    <p class="wow fadeInUp lead text-center">
                    </p>
                </div>
            </div>
        </div>
    </section>
    <section class="mb-0 pb-240">
        <div class="container-fluid">
            
        </div>
    </section>
    <section class="text-section pb-240">
        <div data-jarallax-element="-150" class="text-section-box"></div>
        <div class="container">
            <div class="row text-row">
                <div class="col-lg-6">
                    <div class="text-section-block">
                        <h3>Why do you want Breast Reconstruction in Houston, Texas?</h3>
                        <p>
                            Breast Reconstruction is a reconstructive procedure that rebuilds the breasts by restoring
                            skin, breast tissue and the removed nipple. It is usually performed on women who have
                            undergone breast cancer treatment. Breast Reconstruction involves the use of implants to
                            restore fullness and shape to the breast. Tissue expanders taken from other parts of the
                            body of a candidate for breast reconstruction may also be used.
                        </p>
                        <p>
                            Breast Reconstruction options generally falls into two categories, implant-based
                            reconstruction or Flap reconstruction.
                        </p>
                    </div>
                    <div class="text-section-block">
                        <h3>Implant-based Reconstruction</h3>
                        <p>
                            Breast Reconstruction surgery using breast implants utilizes silicone devises filled with
                            silicone or saline to recreate the natural shape of the breast. Candidates for breast
                            reconstruction can choose their desired size.
                        </p>
                    </div>
                    <div class="text-section-block">
                        <h3>Flap Reconstruction</h3>
                        <p>
                            Sometimes a mastectomy or radiation therapy will leave insufficient tissue on the chest wall
                            to cover and support a breast implant. In such cases, Breast Reconstruction typically
                            requires either a Flap reconstruction technique or tissue expanders.
                        </p>
                        <p>
                            A flap procedure, also known as autologous tissue reconstruction, uses tissue from other
                            parts of your body, such as your abdomen, back, thighs or buttocks to rebuild breast shape.
                            Tissue flaps generally look and behave more naturally than breast implants. For example,
                            their size and appearance may fluctuate with weight gain or weight loss. While breast
                            implants may need to be replaced or are risk of rupture, this is not a concern with tissue
                            flaps.
                        </p>
                        <p>
                            The most common Flap procedures are TRAM flap procedures, transverse rectus abdominis
                            muscle,
                            and DIEP flap procedures, deep inferior epigastric perforators–both use tissue from the
                            abdomen to reconstruct the shape and volume of the breasts.
                        </p>
                    </div>
                </div>
                <div class="col-lg-6 pt-lg-5">
                    <div class="text-section-block">
                        <h3>What procedures are often performed along with Breast Reconstruction?</h3>
                        <p class="align-content-end">
                            Breast reconstruction typically involves multiple procedures performed in stages, and can
                            either begin at the time of mastectomy or be delayed until a later date. A patient
                            considering breast reconstruction may choose to pursue flap and implant reconstruction
                            together.
                        </p>
                    </div>
                    <div class="text-section-block">
                        <h3>What do you want from Breast Reconstruction?</h3>
                        <p class="align-content-end">
                            The plastic surgeons at The Oaks Plastic Surgery want to work with you to achieve your
                            specific goals.
                        </p>
                    </div>
                    <div class="text-section-block">
                        <h3>What can you expect at your initial consultation at The Oaks Plastic Surgery in Houston,
                            Texas?</h3>
                        <p class="align-content-end">
                            If you are interested in Breast Reconstruction in Houston, Texas, an appointment can be made
                            with our reconstructive surgeons–<a href='/danielle-andry-houston'>Dr. Danielle Andry</a> or <a href='/nandi-wijay-houston'>Dr. Nandi Wijay</a>. 
                            You can expect the initial consultation to last an hour or more. In your
                            consultation, Dr. Andry or Dr. Wijay will:

                        </p>
                        <p>
                        <ul>
                            <li>Listen to your specific complaints and goals
                            </li>
                            <li>Perform a thorough examination, focusing on your individual anatomy and measurements
                            </li>
                            <li>Discuss recommendations regarding surgical or nonsurgical techniques that may help you
                                achieve your goals
                            </li>
                            <li>If surgery is the right option for you, Dr. Andry or Dr. Wijay will
                                discuss details of the surgical procedures that are offered and which approach is right
                                for you
                            </li>
                            <li>Preoperative photographs will be taken and the surgical plan will be analyzed for you
                                with use of your photographs
                            </li>
                            <li>The risks and benefits of surgery will be thoroughly outlined for you
                            </li>
                            <li>You will be given ample opportunity to ask questions from both our physicians and staff
                                regarding [procedure] and any other surgical or nonsurgical procedures you may be
                                interested in
                            </li>
                            <li>You will be sent home with a packet of information regarding the procedure including a
                                detailed consent form and instructions for before and after Breast Reconstruction
                            </li>
                        </ul>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="pb-240">
        <div class="container-fluid">
            
        </div>
    </section>
    <section class="pb-240">
        <div class="container-fluid">
            
        </div>
    </section>
