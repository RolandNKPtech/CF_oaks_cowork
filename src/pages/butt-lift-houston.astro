---
// Brazilian Butt Lift in Houston, Texas
// Ported from: butt-lift-houston.php
export const prerender = true;

import Base from "../layouts/Base.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { CATEGORIES_TOP } from "../lib/categories";
---

<Base
  title="Brazilian Butt Lift in Houston, Texas | The Oaks Plastic Surgery"
  description="Brazilian Butt Lift in Houston, Texas at The Oaks Plastic Surgery. Board-certified plastic surgeons offering personalized care."
  headerTitle="Brazilian Butt Lift in Houston, Texas"
  headerImage="/img/butt-lift-hero.jpg"
  headerMarginBottom={60}
  canonical="https://theoaksplasticsurgery.com/butt-lift-houston"
>
<section class="mb-0">
                <div class="container w-new100">
                    <div class="row text-row">
                        <div class="col-lg-12 offset-lg-0 plr-60">
                            <div class="plash-size">
                                
                                    <div class="alert alert-success alert-dismissible" role="alert">
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span
                                                    aria-hidden="true">&times;</span></button>
                                        <strong>Success!</strong> The Oaks Plastic Surgery team will reach out to you shortly!
                                    </div>
                                
                                    
                                        <div class="alert alert-danger alert-dismissible" role="alert">
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span
                                                        aria-hidden="true">&times;</span></button>
                                            <strong>Error!</strong> Empty or Invalid reCaptcha
                                        </div>
                                    
                                
                                <div id="formCarousel" class="carousel slide" data-ride="carousel" data-interval="false">
                                    <form class="carousel-inner" method="post" name="consult">
                                        <div class="carousel-item active">
                                            <div class="plash-size-title">Which body area concerns you the most?</div>
                                            <div class="plash-size-error"></div>
                                            <div class="plash-size-elements elements-grid">
                                                <label>
                                                    <input type="checkbox" value="Stomach" name="consult[option_one][]" />
                                                    <span class="text">Stomach</span>
                                                </label>
                                                <label>
                                                    <input type="checkbox" value="Hips" name="consult[option_one][]" />
                                                    <span class="text">Hips</span>
                                                </label>
                                                <label>
                                                    <input type="checkbox" value="Back " name="consult[option_one][]" />
                                                    <span class="text">Back</span>
                                                </label>
                                                <label>
                                                    <input type="checkbox" value="Thighs" name="consult[option_one][]" />
                                                    <span class="text">Thighs</span>
                                                </label>
                                                <label>
                                                    <input type="checkbox" value="Butt" name="consult[option_one][]" />
                                                    <span class="text">Butt</span>
                                                </label>
                                                <input type="text" hidden value="Body areas of concern" name="consult[option_one_title]" />
                                            </div>
                                            <div class="plash-size-click">
                                                <a href="#" class="blue-click" onclick="validateSlideOne(event,0)">Continue</a>
                                            </div>
                                        </div>
                                        <div class="carousel-item">
                                            <div class="plash-size-title">Would you like more?</div>
                                            <div class="plash-size-error"></div>
                                            <div class="plash-size-elements elements-grid four-columns">
                                                <label>
                                                    <input type="radio" value="Butt Projection" name="consult[option_two][]" />
                                                    <span class="text">Butt Projection</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Hip Projection" name="consult[option_two][]" />
                                                    <span class="text">Hip Projection</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Both" name="consult[option_two][]" />
                                                    <span class="text">Both</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Neither" name="consult[option_two][]" />
                                                    <span class="text">Neither</span>
                                                </label>
                                                <input type="text" hidden value="Would you like more?" name="consult[option_two_title]" />
                                            </div>
                                            <div class="plash-size-click">
                                                <a href="#" class="blue-click" onclick="validateSlideTwo(event,1)">Continue</a>
                                                <a href="#" class="blue-click" data-target="#formCarousel" data-slide-to="0">Previous</a>
                                            </div>
                                        </div>
                                        <div class="carousel-item">
                                            <div class="plash-size-title">Select a Surgeon</div>
                                            <div class="plash-size-error"></div>
                                            <div class="plash-size-elements elements-grid four-columns">
                                                <label>
                                                    <input type="radio" value="Dr. Danielle Andry" name="consult[doctor]" />
                                                    <span class="text">Dr. Danielle Andry</span>
                                                </label>
                                                <label>
                                                    <input type="radio" value="Dr. Nandi Wijay, MD" name="consult[doctor]" />
