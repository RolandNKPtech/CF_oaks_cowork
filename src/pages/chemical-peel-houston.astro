        <div class="container">
            <div class="row">
                <div class="col-lg-8 offset-lg-2">
                    <p class="wow fadeInUp lead text-center">
                        A Chemical Peel helps to improve the appearance of the skin by smoothing the outer layer of skin
                        and reducing the severity of wrinkles, scarring and texture.
                    </p>
                </div>
            </div>
        </div>
    </section>
