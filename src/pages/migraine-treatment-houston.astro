export const prerender = true;

import Base from "../layouts/Base.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { CATEGORIES_TOP } from "../lib/categories";
---

<Base
  title="Surgical Migraine Treatment in Houston, Texas | The Oaks Plastic Surgery"
  description="Surgical Migraine Treatment in Houston, Texas at The Oaks Plastic Surgery. Board-certified plastic surgeons offering personalized care."
  headerTitle="Surgical Migraine Treatment in Houston, Texas"
  headerImage="/img/brow-lift-hero.jpg"
  headerMarginBottom={60}
  canonical="https://theoaksplasticsurgery.com/migraine-treatment-houston"
>
<section class="mb-0">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-8 offset-lg-2">
                            <p class="wow fadeInUp lead text-center">
                                For migraine sufferers who don’t respond well to other treatments, surgical migraine treatment could help to alleviate your symptoms and restore your quality of life.
                            </p>
                        </div>
                    </div>
                </div>
            </section>
            <section class="mb-0">
                <div class="container-fluid">
                    
                </div>
            </section>
            <section class="text-section">
                <div data-jarallax-element="-150" class="text-section-box"></div>
                <div class="container">
                    <div class="row text-row">
                        <div class="col-lg-6">
                            <div class="text-section-block">
                                <h3>Why do you want a Migraine Treatment in Houston?</h3>
                                <p>A migraine is the most common neurological condition in the developed world, with around 15 percent of men and women suffering from chronic headaches globally. Yet, despite its prevalence, one of the most frustrating things for sufferers is that some people believe those that are affected are simply hypochondriacs. The truth is that unless you suffer from migraines, you cannot appreciate just how debilitating and excruciating the pain can be.</p>
                                <p>The main reason our patients come to The Oaks Plastic Surgery is to regain control of their lives. They no longer want to be limited by a condition that can significantly reduce their feelings of health and wellbeing. They also want to be rid of an excruciating pain that strikes without warning and can last for up to 72 hours at a time.</p>
                            </div>                            
                            <div class="text-section-block">
                                <h3>What do you want from Surgical Migraine Treatment?</h3>
                                <p>Studies have shown that success rates for surgical migraine treatment are above 70 percent, with more than one-third of patients experiencing total relief from the symptoms of migraines. After surgery, some patients may still get occasional headaches, but they decrease in their frequency, duration and/or their intensity. That leads to improvements in their health-related quality of life.</p>
                            </div>                            
                        </div>
                        <div class="col-lg-6 pt-lg-5">
                            <div class="text-section-block">
                                <h3>What can you expect during your initial Migraine Treatment consultation?</h3>
                                <p class="align-content-end">
                                    If you are considering surgical migraine treatment at our surgery in Houston, Texas, the first step will be to book an initial consultation with one of our plastic surgeons. The initial consultation will typically last one hour or more and involve a detailed discussion about every element of the treatment. Your surgeon will:
                                </p>
                                <ul>
                                    <li>Discuss the specific complaints you experience and listen to your goals</li>
                                    <li>Perform a thorough examination that will focus on your specific anatomy</li>
                                    <li>Talk to you about non-surgical techniques that could help you achieve your goals</li>
                                    <li>Discuss the risks associated with the treatment and the potential benefits</li>
                                    <li>Give you the opportunity to ask any questions and air any concerns you have</li>
                                    <li>You will receive a detailed information pack regarding the surgical migraine treatment. That will include a consent form and instructions you should follow before and after the surgery</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section class="pb-240">
                <div class="container-fluid">
                    
                </div>
            </section>
