---
/**
 * Admin Dashboard — protected by middleware (requires admin role).
 * SSR page: shows contact submissions, gallery/forum stats.
 */
export const prerender = false;

const user = Astro.locals.user as any;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard — TOPS</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
    }
    .topbar {
      background: #1a1a1a;
      color: #fff;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar h1 { font-size: 1.125rem; font-weight: 600; }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;
    }
    .btn-logout {
      background: transparent;
      color: #ccc;
      border: 1px solid #555;
      padding: 0.375rem 0.75rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.8125rem;
      transition: all 0.15s;
    }
    .btn-logout:hover { color: #fff; border-color: #999; }
    .container {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.5rem;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.25rem;
      margin-bottom: 2rem;
    }
    .card {
      background: #fff;
      border-radius: 10px;
      padding: 1.5rem;
      box-shadow: 0 1px 8px rgba(0,0,0,0.05);
    }
    .card h3 {
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #888;
      margin-bottom: 0.5rem;
    }
    .card .value {
      font-size: 2rem;
      font-weight: 700;
      color: #1a1a1a;
    }
    .card .sub { font-size: 0.8125rem; color: #888; margin-top: 0.25rem; }
    .section-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: #1a1a1a;
      margin-bottom: 1rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 1px 8px rgba(0,0,0,0.05);
    }
    th, td {
      text-align: left;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
    }
    th {
      background: #f9fafb;
      font-weight: 600;
      color: #555;
      border-bottom: 1px solid #eee;
    }
    td { border-bottom: 1px solid #f3f4f6; }
    tr:last-child td { border-bottom: none; }
    .empty { color: #999; font-style: italic; padding: 2rem; text-align: center; }
    .nav-links { display: flex; gap: 1.5rem; margin-bottom: 2rem; }
    .nav-links a {
      color: #2563eb;
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
    }
    .nav-links a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>TOPS Admin</h1>
    <div class="topbar-right">
      <span>{user?.name || user?.email}</span>
      <button class="btn-logout" id="btn-logout">Sign Out</button>
    </div>
  </div>

  <div class="container">
    <div class="nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/admin/contacts">Contacts</a>
      <a href="/admin/gallery">Gallery</a>
      <a href="/admin/forum">Forum</a>
    </div>

    <div class="grid" id="stats">
      <div class="card">
        <h3>Contact Submissions</h3>
        <div class="value" id="stat-contacts">—</div>
        <div class="sub">Total received</div>
      </div>
      <div class="card">
        <h3>Gallery Cases</h3>
        <div class="value" id="stat-gallery">—</div>
        <div class="sub">Before/after</div>
      </div>
      <div class="card">
        <h3>Forum Questions</h3>
        <div class="value" id="stat-forum">—</div>
        <div class="sub">Published Q&A</div>
      </div>
    </div>

    <h2 class="section-title">Recent Contact Submissions</h2>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Doctor</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody id="contacts-body">
        <tr><td colspan="5" class="empty">Loading...</td></tr>
      </tbody>
    </table>
  </div>

  <script>
    // Sign out
    document.getElementById("btn-logout")?.addEventListener("click", async () => {
      await fetch("/api/auth/sign-out", { method: "POST", credentials: "include" });
      window.location.href = "/admin/login";
    });

    // Load stats
    async function loadStats() {
      try {
        const [gRes, fRes] = await Promise.all([
          fetch("/api/gallery?limit=1"),
          fetch("/api/forum?limit=1"),
        ]);
        const g = await gRes.json();
        const f = await fRes.json();
        const statGallery = document.getElementById("stat-gallery");
        const statForum = document.getElementById("stat-forum");
        if (statGallery) statGallery.textContent = String(g.total || 0);
        if (statForum) statForum.textContent = String(f.total || 0);
      } catch { /* stats are non-critical */ }

      // Contact count via a dedicated admin endpoint (or we can query D1 directly)
      // For now show "—" until we add an admin contacts API
    }

    loadStats();
  </script>
</body>
</html>
