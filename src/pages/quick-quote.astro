---
// Quick Quote
// Ported from: quick-quote.php
export const prerender = true;

import Base from "../layouts/Base.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { CATEGORIES_TOP } from "../lib/categories";
---

<Base
  title="Quick Quote | The Oaks Plastic Surgery"
  description="Quick Quote in Houston, TX at The Oaks Plastic Surgery. Board-certified plastic surgeons offering personalized care."
  headerTitle="Quick Quote"
  headerImage="/img/header-contact-us.png"
  headerMarginBottom={60}
  canonical="https://theoaksplasticsurgery.com/quick-quote"
>
<section class="mb-0">
            <div class="container w-new100">
                <div class="row text-row">
                    <div class="col-lg-12 offset-lg-0 plr-60 my-5 py-5">
                        <div class="plash-size m-0">
                            
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <section>
            <div class="container-fluid">
                <div class="row">
                    
                </div>
            </div>
        </section>
  <section>
    <div class="container-fluid">
      <div class="row">
        <CategoryGrid categories={CATEGORIES_TOP} />
      </div>
    </div>
  </section>
</Base>
