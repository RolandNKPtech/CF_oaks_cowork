<!-- Navbar -->
<nav class="navbar navbar-expand-lg fixed-top">
  <a class="btn btn-menu text-left open-menu" onclick="showoverlay('mainmenu')">MENU</a>
  <a href="/" class="navbar-brand m-auto">
    <img src="/img/logo.png?9-01-2022" alt="tops" />
  </a>

  {isGallery ? (
    <span class="btn btn-outline-light btn-call">
      <a href={`tel:${SITE.phone}`}><i class="fal fa-phone"></i></a>
      <a class="form-trigger" href="/contact-us">QUICK QUOTE</a>
    </span>
  ) : (
    <span class="btn btn-outline-light btn-call">
      <a href={`tel:${SITE.phone}`}><i class="fal fa-phone"></i></a>
      <span class="form-trigger" onclick={`service_cta_popup('${interestedIn}')`}>QUICK QUOTE</span>
    </span>
  )}
</nav>

