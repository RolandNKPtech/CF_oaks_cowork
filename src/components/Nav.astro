---
import { SITE, INTERESTED_IN } from "../lib/constants";

const currentPath = Astro.url.pathname;
const interestedIn = INTERESTED_IN[currentPath] || "";
const isGallery = currentPath.includes("tops-gallery") || currentPath.includes("gallery");
